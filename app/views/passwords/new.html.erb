<h1>パスワード再設定</h1>

<p class="auth-description">
  登録したメールアドレスを入力してください
</p>

<% if @user.errors.any? %>
  <div class="error-messages">
    <% @user.errors.full_messages.each do |message| %>
      <p><%= message %></p>
    <% end %>
  </div>
<% end %>

<%= form_with url: password_path, method: :post, local: true do |f| %>
  <div class="field">
    <%= f.email_field :email_address, placeholder: "example@example.com", required: true %>
  </div>

  <div class="actions">
    <%= f.submit "再設定リンクを送信" %>
  </div>
<% end %>

<div class="auth-back-link">
  <%= link_to "ログインに戻る", new_session_path %>
</div>