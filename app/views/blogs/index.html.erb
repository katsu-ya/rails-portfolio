

<div class="container mt-4">
  <div class="col-md-8 mx-auto">

  <h1 class="display-5 text-primary text-center mb-4">mini blog</h1>

<% @posts.each do |post| %>
      <div class="post-card mb-4">
        <h2 class="fs-5">
          <%= link_to post.title, post_path(post), class: "text-decoration-none" %>
        </h2>

<p class="text-muted mb-2">
          <%= post.created_at.strftime("%Y/%m/%d") %>
        </p>


        <p>
          <%= truncate(post.content, length: 120) %>
        </p>
      </div>
    <% end %>

  </div>
</div>

<div class="new-post-button">
  <%= link_to "新規投稿", new_post_path, class: "btn btn-primary shadow" %>
</div>


<nav class="navbar navbar-expand-lg navbar-light bg-white mb-4">
  <div class="container">
    <%= link_to "mini blog", posts_path, class: "navbar-brand fw-bold text-primary" %>

    <div class="ms-auto">
      <%= link_to "ホーム", posts_path, class: "btn btn-outline-secondary me-2" %>
    </div>
  </div>
</nav>
