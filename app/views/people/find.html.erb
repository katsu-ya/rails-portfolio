<h1 class="display-4 text-primary">
  People#Find</h1>
<p><%= @msg %></p>
<%= form_with url: people_find_path do |f| %>
<div class="form-group">
  <label for="find">Find</label>
  <%=f.text_field "find", class:"form-control" %>
</div>
<%= submit_tag("Click") %>
<% end %>

<table class="table">
  <tr>
    <th>Id</th><th>Name</th><th>Age</th><th>Mail</th>
  </tr>
  <% @people.each do |p| %>
  <tr>
    <td><%= p.id %></td>
    <td><%= p.name %></td>
    <td><%= p.age %></td>
    <td><%= p.mail %></td>
  </tr>
  <% end %>
</table>