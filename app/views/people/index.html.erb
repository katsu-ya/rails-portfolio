<h1 class="display-4 text-primary">People#index</h1>


<table class="table">
  <% @people.each do |person| %>
    <tr>
      <td><%= person.id %></td>
      <td><%= person.name %></td>
      <td><%= person.mail %></td>
      <td>
    
    

        <%= link_to "Messages", person_messages_path(person) %>



      </td>
    </tr>
  <% end %>
</table>




<script>
function delData(num){
    if (confirm('このデータを削除しますか？')){
        document.location = "/people/delete/" + num;
    }
    return false;
}
</script>