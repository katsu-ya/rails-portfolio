<% if flash[:notice] %>
  <div class="alert alert-info" role="alert">
    <%= flash[:notice] %>
  </div>
<% end %>
<%= form_with method: :post do |f| %>
  <div class="form-group">
    <label for="name">名前</label>
    <%= f.text_field :name, class:"form-control" %>
  </div>
  <div class="form-group">
    <label for="mail">メール</label>
    <%= f.text_field :mail, class:"form-control" %>
  </div>
  <div class="form-group">
    <label for="msg">メッセージ</label>
    <%= f.text_area :msg,class:"form-control" %>
  </div>
  <%= f.submit :Click, class:"btn btn-primary" %>
<% end %>

<table class="table mt-4">
  <tr>
    <th style="width:50%">メッセージ</th>
    <th>名前</th>
    <th>メール</th>
    <th>投稿日時</th>
  </tr>
  <% @msg_data.each do |key,obj| %>
  <tr>
    <td class="msg"><%= obj['msg'] %></td>
    <td class="name"><%= obj['name'] %></td>
    <td class="mail"><%= obj['mail'] %></td>
    <td class="time"><%= Time.at(key.to_i) %></td>
  </tr>
  <% end %>
</table>